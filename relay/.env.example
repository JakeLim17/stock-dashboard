# ─────────────────────────────────────────────────────────────────────
# stock-dashboard relay 서버 환경변수
#
# 운영 시 .env.local (또는 docker --env-file, systemd EnvironmentFile) 로
# 주입한다. 절대 git 에 커밋 금지.
# ─────────────────────────────────────────────────────────────────────

# 리스닝 포트
PORT=8787

# Vercel proxy 와 공유하는 비밀. 32자 이상 랜덤 권장.
# 생성 예: openssl rand -hex 32
# 비워두면 인증 비활성(로컬 테스트용). 운영에선 반드시 설정.
RELAY_SHARED_SECRET=

# 한국투자증권 KIS Open API 키 (메인 stock-dashboard 와 같은 값 사용)
KIS_APP_KEY=
KIS_APP_SECRET=

# REST base — approval_key 발급 호출용
# 실전: https://openapi.koreainvestment.com:9443
# 모의: https://openapivts.koreainvestment.com:29443
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# (선택) 명시적으로 WebSocket URL 지정. 비워두면 KIS_USE_MOCK 으로 자동 분기.
# 실전: wss://ops.koreainvestment.com:21000
# 모의: wss://ops.koreainvestment.com:31000
KIS_WS_URL=

# 1 = 모의 환경 사용 (:31000 + openapivts)
KIS_USE_MOCK=0
