# ──────────────────────────────────────────────────────────────
# 실시간 주식 대시보드 환경변수
# 모두 선택 사항. 비워두면 Yahoo Finance + Google News RSS만 사용.
# ──────────────────────────────────────────────────────────────

# (강력 권장) Vercel 배포 시 비밀번호 게이트
# 설정하면 /login 페이지에서 비번 1회 입력 → 30일 동안 쿠키로 자동 통과
# 비워두면 인증 비활성 (로컬 개발 편의)
DASHBOARD_PASS=

# 한국투자증권 KIS Open API (실시간 시세·수급)
# 발급: https://apiportal.koreainvestment.com → Open API 신청 → 모의투자 키 추천
#   - 키를 채우면 KIS를 사용하되, 토큰은 캐시에 저장해 재사용
#   - 장애/문자 폭주 대응으로 끄려면 KIS_ENABLED=0
#   - KIS는 현재가에만 사용. 지수/일봉/수급/부가데이터는 빠른 기존 경로 사용
# 실전: https://openapi.koreainvestment.com:9443
# 모의: https://openapivts.koreainvestment.com:29443
KIS_ENABLED=
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443

# KIS 토큰 발급 1분당 1회(EGW00133) 차단 시 cooldown 시간 (ms). 기본 300000(5분).
# KIS는 토큰 신규 발급 시 카톡 알림(1일 1회 정책)을 보내므로 보수적으로 길게 두는 게 안전.
# 60초 등 짧게 두면 폴링 사이클 안에서 재시도가 폭주해 카톡 알림이 여러 번 오는 사고가 있었다.
KIS_TOKEN_COOLDOWN_MS=

# ──────────────────────────────────────────────────────────────
# Vercel KV / Upstash Redis — KIS 토큰을 인스턴스 간 공유하는 cross-instance 캐시
# ──────────────────────────────────────────────────────────────
# Vercel serverless 환경에서는 메모리/디스크 캐시가 lambda 인스턴스마다 휘발/격리되어
# cold start 마다 KIS 토큰을 신규 발급하게 된다 → 카톡 알림 폭주.
# Vercel KV(Upstash) 가 연결되면 모든 인스턴스가 같은 토큰을 공유해 24h 에 1회만 발급.
#
# 셋업: Vercel 대시보드 → Storage → Create Database → KV/Upstash 선택 → 프로젝트 Connect.
#       → 아래 변수가 자동 주입됨 → Redeploy 1회.
# 자세한 가이드: docs/KIS_TOKEN_SETUP.md
KV_REST_API_URL=
KV_REST_API_TOKEN=
# (선택, 옛 변수명) Upstash 직접 연결 시 자동 주입되는 변수. 위 KV_* 가 우선.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
