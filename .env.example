# ──────────────────────────────────────────────────────────────
# 실시간 주식 대시보드 환경변수
# 모두 선택 사항. 비워두면 Yahoo Finance + Google News RSS만 사용.
# ──────────────────────────────────────────────────────────────

# (강력 권장) Vercel 배포 시 비밀번호 게이트
# 설정하면 /login 페이지에서 비번 1회 입력 → 30일 동안 쿠키로 자동 통과
# 비워두면 인증 비활성 (로컬 개발 편의)
DASHBOARD_PASS=

# (선택) 한국투자증권 KIS Developers — 외인/기관 실수급 데이터용
# https://apiportal.koreainvestment.com 에서 발급
KIS_APP_KEY=
KIS_APP_SECRET=
# 실전: https://openapi.koreainvestment.com:9443
# 모의: https://openapivts.koreainvestment.com:29443
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443
