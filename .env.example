# ──────────────────────────────────────────────────────────────
# 실시간 주식 대시보드 환경변수
# 모두 선택 사항. 비워두면 Yahoo Finance + Google News RSS만 사용.
# ──────────────────────────────────────────────────────────────

# (강력 권장) Vercel 배포 시 비밀번호 게이트
# 설정하면 /login 페이지에서 비번 1회 입력 → 30일 동안 쿠키로 자동 통과
# 비워두면 인증 비활성 (로컬 개발 편의)
DASHBOARD_PASS=

# 한국투자증권 KIS Open API (실시간 시세·수급)
# 발급: https://apiportal.koreainvestment.com → Open API 신청 → 모의투자 키 추천
#   - 키를 채우면 KIS를 사용하되, 토큰은 캐시에 저장해 재사용
#   - 장애/문자 폭주 대응으로 끄려면 KIS_ENABLED=0
#   - KIS는 현재가에만 사용. 지수/일봉/수급/부가데이터는 빠른 기존 경로 사용
# 실전: https://openapi.koreainvestment.com:9443
# 모의: https://openapivts.koreainvestment.com:29443
KIS_ENABLED=
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443

# KIS 토큰 발급 1분당 1회(EGW00133) 차단 시 cooldown 시간 (ms). 기본 300000(5분).
# KIS는 토큰 신규 발급 시 카톡 알림(1일 1회 정책)을 보내므로 보수적으로 길게 두는 게 안전.
# 60초 등 짧게 두면 폴링 사이클 안에서 재시도가 폭주해 카톡 알림이 여러 번 오는 사고가 있었다.
KIS_TOKEN_COOLDOWN_MS=

# ──────────────────────────────────────────────────────────────
# Vercel KV / Upstash Redis — KIS 토큰을 인스턴스 간 공유하는 cross-instance 캐시
# ──────────────────────────────────────────────────────────────
# Vercel serverless 환경에서는 메모리/디스크 캐시가 lambda 인스턴스마다 휘발/격리되어
# cold start 마다 KIS 토큰을 신규 발급하게 된다 → 카톡 알림 폭주.
# Vercel KV(Upstash) 가 연결되면 모든 인스턴스가 같은 토큰을 공유해 24h 에 1회만 발급.
#
# 셋업: Vercel 대시보드 → Storage → Create Database → KV/Upstash 선택 → 프로젝트 Connect.
#       → 아래 변수가 자동 주입됨 → Redeploy 1회.
# 자세한 가이드: docs/KIS_TOKEN_SETUP.md
KV_REST_API_URL=
KV_REST_API_TOKEN=
# (선택, 옛 변수명) Upstash 직접 연결 시 자동 주입되는 변수. 위 KV_* 가 우선.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ──────────────────────────────────────────────────────────────
# KIS WebSocket 실시간 (체결가만, Phase 1)
# ──────────────────────────────────────────────────────────────
# 활성화 시: /api/realtime/stream (SSE) → KIS WS H0STCNT0(체결가) 구독.
#           카드의 현재가만 즉시 갱신 (등락 자동 재계산). 기존 5초 polling 은 그대로 유지 — 백업.
# OFF (기본) 시: SSE 연결 전혀 없음, EventSource 생성 안 함 → 회귀 0.
#
# 활성화하려면: 이 값을 "true" 로 두고 Vercel Redeploy. (클라이언트 빌드에 박혀 노출되므로 NEXT_PUBLIC_ prefix.)
NEXT_PUBLIC_REALTIME_ENABLED=false

# KIS WebSocket 엔드포인트. 비워두면 KIS_BASE_URL 의 openapivts 포함 여부로 자동 분기
# (실전 :21000 / 모의 :31000). 명시하려면 아래 둘 중 하나.
# 실전: wss://ops.koreainvestment.com:21000
# 모의: wss://ops.koreainvestment.com:31000
# 주의: Vercel 함수가 한국 외 리전이면 직접 연결이 1006 으로 즉시 끊김 → KIS_WS_RELAY_URL 사용.
KIS_WS_URL=wss://ops.koreainvestment.com:21000

# ──────────────────────────────────────────────────────────────
# KIS WebSocket Relay (한국 IP 호스트 우회)
# ──────────────────────────────────────────────────────────────
# 비워두면 /api/realtime/stream 이 Vercel 함수에서 직접 KIS WS 시도.
#   → Vercel 리전이 한국 외(sin1/hnd1 등)면 1006 으로 즉시 종료된다.
#
# relay 호스팅(Oracle Cloud Seoul / 라즈베리파이 / NAS 등) 후 https URL 을 여기 넣으면
# /api/realtime/stream 이 SSE proxy 로 동작 — 자세한 가이드는 `relay/README.md`.
KIS_WS_RELAY_URL=

# relay 와 공유하는 비밀(`x-relay-secret` 헤더로 전달).
# relay 의 RELAY_SHARED_SECRET 과 동일 값. `openssl rand -hex 32`.
KIS_WS_RELAY_SECRET=
