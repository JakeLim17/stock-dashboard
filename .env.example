# ──────────────────────────────────────────────────────────────
# 실시간 주식 대시보드 환경변수
# 모두 선택 사항. 비워두면 Yahoo Finance + Google News RSS만 사용.
# ──────────────────────────────────────────────────────────────

# (강력 권장) Vercel 배포 시 비밀번호 게이트
# 설정하면 /login 페이지에서 비번 1회 입력 → 30일 동안 쿠키로 자동 통과
# 비워두면 인증 비활성 (로컬 개발 편의)
DASHBOARD_PASS=

# 한국투자증권 KIS Open API (실시간 시세·수급)
# 발급: https://apiportal.koreainvestment.com → Open API 신청 → 모의투자 키 추천
#   - KIS는 토큰 발급 때 카톡/SMS 알림이 올 수 있어 기본 OFF
#   - 키를 채워도 KIS_ENABLED=1 을 명시하지 않으면 KIS 호출은 시도하지 않음
#   - OFF 상태에서는 기존 네이버/Yahoo/mock fallback 으로 그대로 동작
# 실전: https://openapi.koreainvestment.com:9443
# 모의: https://openapivts.koreainvestment.com:29443
KIS_ENABLED=0
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443
